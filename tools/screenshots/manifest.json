{
  "defaults": {
    "viewport": { "width": 1440, "height": 900 },
    "compress": true,
    "cleanup": [
      { "action": "eval", "script": "document.querySelectorAll('.callout-note').forEach(el => { if (el.textContent.includes('Pre-release')) el.remove() })" },
      { "action": "eval", "script": "document.querySelectorAll('[class*=prerelease],[class*=preview]').forEach(el => el.remove())" }
    ],
    "dark": {
      "toggle": ".quarto-color-scheme-toggle",
      "ready": "body.quarto-dark",
      "readyLight": "body.quarto-light",
      "settle": 500
    }
  },
  "screenshots": [
    {
      "name": "about-jolla",
      "output": "docs/websites/images/about-jolla.png",
      "dark": true,
      "source": { "type": "example", "project": "examples/about-pages", "page": "about-jolla.html" },
      "capture": {
        "viewport": { "width": 1200, "height": 900 },
        "zoom": 1.15,
        "clip": [".quarto-about-jolla"],
        "trim": true
      },
      "doc": {
        "file": "docs/websites/website-about.qmd",
        "alt": "Screenshot of an About page using the jolla template. It has a round headshot of the author in the center with the name, a description, and icons for Email, Bluesky, GitHub below."
      }
    },
    {
      "name": "about-trestles",
      "output": "docs/websites/images/about-trestles.png",
      "dark": true,
      "source": { "type": "example", "project": "examples/about-pages", "page": "about-trestles.html" },
      "capture": {
        "viewport": { "width": 1200, "height": 900 },
        "zoom": 1.15,
        "clip": [".quarto-about-trestles"],
        "trim": true,
        "maxHeight": 750
      },
      "doc": {
        "file": "docs/websites/website-about.qmd",
        "alt": "Screenshot of an About page using the trestles template. It has a headshot of the author and links on the left and the body of the about page on the right."
      }
    },
    {
      "name": "about-solana",
      "output": "docs/websites/images/about-solana.png",
      "dark": true,
      "source": { "type": "example", "project": "examples/about-pages", "page": "about-solana.html" },
      "capture": {
        "viewport": { "width": 1200, "height": 900 },
        "zoom": 1.15,
        "clip": [".quarto-about-solana"],
        "trim": true
      },
      "doc": {
        "file": "docs/websites/website-about.qmd",
        "alt": "Screenshot of an About page using the solana template. It has the author name, links, and body on the left and a rectangular headshot on the right."
      }
    },
    {
      "name": "about-marquee",
      "output": "docs/websites/images/about-marquee.png",
      "dark": true,
      "source": { "type": "example", "project": "examples/about-pages", "page": "about-marquee.html" },
      "capture": {
        "viewport": { "width": 1200, "height": 1500 },
        "zoom": 1.15,
        "clip": [".quarto-about-marquee"],
        "trim": true
      },
      "doc": {
        "file": "docs/websites/website-about.qmd",
        "alt": "Screenshot of an About page using the marquee template. It has a large image at the top, followed by the author name, body, and links below."
      }
    },
    {
      "name": "about-broadside",
      "output": "docs/websites/images/about-broadside.png",
      "dark": true,
      "source": { "type": "example", "project": "examples/about-pages", "page": "about-broadside.html" },
      "capture": {
        "viewport": { "width": 1200, "height": 900 },
        "zoom": 1.15,
        "clip": [".quarto-about-broadside"],
        "trim": true
      },
      "doc": {
        "file": "docs/websites/website-about.qmd",
        "alt": "Screenshot of an About page using the broadside template. It has the author image on the left and the name, body, and links on the right."
      }
    },
    {
      "name": "navbar-tools",
      "output": "docs/websites/images/navbar-tools.png",
      "dark": true,
      "source": { "type": "example", "project": "examples/navbar-tools", "page": "index.html" },
      "capture": {
        "viewport": { "width": 1440, "height": 400 },
        "interaction": [
          { "action": "click", "selector": ".bi-github", "wait": ".dropdown-menu.show" }
        ],
        "clip": [".quarto-navbar-tools", ".dropdown-menu.show"]
      },
      "doc": {
        "file": "docs/websites/website-navigation.qmd",
        "alt": "The right section of a Quarto navbar containing a Bluesky and Github logo. The Github logo is selected and a menu is underneath it with two items: 'Source Code' and 'Report a Bug'"
      }
    },
    {
      "name": "sidebar-tools",
      "output": "docs/websites/images/tools.png",
      "dark": true,
      "source": { "type": "url", "url": "https://quarto-dev.github.io/quarto-demo/html-themes.html" },
      "capture": {
        "viewport": { "width": 992, "height": 600 },
        "interaction": [
          { "action": "click", "selector": "#quarto-navigation-tool-dropdown-0", "wait": ".dropdown-menu.show" }
        ],
        "clip": ["#quarto-sidebar", ".dropdown-menu.show"],
        "maxHeight": 320
      },
      "doc": {
        "file": "docs/websites/website-navigation.qmd",
        "alt": "A Quarto sidebar showing the site title with Bluesky and GitHub icons. The GitHub icon is selected and a dropdown menu shows two items: 'Source Code' and 'Report a Bug'. Below are a search box and navigation sections."
      }
    },
    {
      "name": "nav-side-anchored",
      "output": "docs/websites/images/nav-side-anchored.png",
      "dark": true,
      "source": { "type": "example", "project": "examples/quarto-demo", "page": "html-themes.html" },
      "capture": {
        "viewport": { "width": 1200, "height": 800 }
      },
      "doc": {
        "file": "docs/websites/website-navigation.qmd",
        "alt": "A screenshot of a Quarto document where the sidebar is colored gray."
      }
    },
    {
      "name": "nav-side-floating",
      "output": "docs/websites/images/nav-side-floating.png",
      "dark": true,
      "source": { "type": "example", "project": "examples/quarto-demo", "profile": "floating", "page": "html-themes.html" },
      "capture": {
        "viewport": { "width": 1200, "height": 800 }
      },
      "doc": {
        "file": "docs/websites/website-navigation.qmd",
        "alt": "A screenshot of a Quarto document where the sidebar has a white background and is closer to the body text."
      }
    },
    {
      "name": "nav-breadcrumbs",
      "output": "docs/websites/images/nav-breadcrumbs.png",
      "dark": true,
      "source": { "type": "example", "project": "examples/breadcrumbs", "page": "tutorials.html" },
      "capture": {
        "viewport": { "width": 1200, "height": 400 },
        "clip": ["#title-block-header"],
        "trim": true
      },
      "doc": {
        "file": "docs/websites/website-navigation.qmd",
        "alt": "Screenshot of a webpage. Above the header 'Tutorials' is the linked text 'Tutorials > Tutorial Landing'."
      }
    },
    {
      "name": "repo-actions",
      "output": "docs/websites/images/repo-actions.png",
      "dark": true,
      "source": { "type": "example", "project": "examples/quarto-demo", "profile": "repo-actions", "page": "html-themes.html" },
      "capture": {
        "viewport": { "width": 900, "height": 600 },
        "zoom": 1.25,
        "cleanup": [
          { "action": "eval", "script": "document.getElementById('quarto-header').style.display = 'none'" },
          { "action": "eval", "script": "document.getElementById('quarto-sidebar').style.display = 'none'" },
          { "action": "eval", "script": "document.getElementById('quarto-margin-sidebar')?.style.setProperty('margin-top', '0')" }
        ],
        "spotlight": {
          "selector": ".toc-actions",
          "elevate": "#quarto-margin-sidebar",
          "dim": "#TOC.toc-active > ul:first-of-type",
          "overlay": 0.5,
          "radius": "6px",
          "padding": "8px"
        }
      },
      "doc": {
        "file": "docs/websites/website-navigation.qmd",
        "alt": "A screen shot of a Quarto document. Underneath the page table of contents on the right side are three options: 'Edit this page', 'View source' and 'Report an issue'. There is a Github icon to the left of 'Edit this Page.'"
      }
    },
    {
      "name": "myblog",
      "output": "docs/websites/images/myblog.png",
      "dark": true,
      "source": { "type": "example", "project": "examples/myblog", "page": "index.html" },
      "capture": {
        "viewport": { "width": 1440, "height": 900 },
        "maxHeight": 640
      },
      "doc": {
        "file": "docs/websites/website-blog.qmd",
        "alt": "Screenshot of a blog listing page with a navbar showing the blog name, About link, GitHub and Bluesky icons, and two blog posts with thumbnail images and categories."
      }
    }
  ]
}
